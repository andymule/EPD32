#pragma once

// Optional development-time WiFi credentials.
//
// Normal operation does NOT need this file: the device collects WiFi
// credentials at runtime through the captive setup portal and stores them in
// NVS. Copy this file to "Secrets.h" only if you want to hardcode credentials
// for local development. "Secrets.h" is gitignored.
//
// The weather (Open-Meteo) and geolocation (ip-api.com) services are keyless,
// so no API keys are required here.

#define DEV_WIFI_SSID ""
#define DEV_WIFI_PASSWORD ""
